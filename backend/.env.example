# ── Server ─────────────────────────────────────────────
PORT=3000

# ── AWS General ────────────────────────────────────────
AWS_REGION=ap-south-1

# ── Cognito (JWT verification) ─────────────────────────
# Found in: AWS Console → Cognito → User Pools → <pool> → Overview
COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXX
# Found in: AWS Console → Cognito → User Pools → <pool> → App clients
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── DynamoDB ───────────────────────────────────────────
DYNAMODB_TABLE_NAME=Claims

# ── S3 ─────────────────────────────────────────────────
S3_BUCKET_NAME=claimiq-documents

# ── SES ────────────────────────────────────────────────
# Must be a verified sender identity in AWS SES
SES_SENDER_EMAIL=no-reply@yourdomain.com
